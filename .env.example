# ============================================================
# MechDash - Environment Variables
# ============================================================
# Copy this to .env (command: cp .env.example .env), then update values below.

# --- DATABASE ---
# Password for the built-in PostgreSQL container.
# IMPORTANT: Use ONLY letters and numbers (no @, :, /, ?, #, or other special characters).
DB_PASSWORD=MySecurePassword123

# --- AUTHENTICATION ---
# Random secret string used to sign authentication tokens.
# IMPORTANT: Generate a secure random string!
# Mac/Linux:         openssl rand -base64 32
# Windows PowerShell: [Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))
NEXTAUTH_SECRET=replace-with-a-random-string-at-least-32-characters-long

# Your app's URL. For local Docker, leave as http://localhost:3000.
# For a public server, set to your domain (e.g., https://mechdash.yourdomain.com).
NEXTAUTH_URL=http://localhost:3000

# --- INITIAL ADMIN ACCOUNT ---
# Created automatically on first startup. Change password after first login.
ADMIN_EMAIL=admin@mechdash.local
ADMIN_PASSWORD=admin123456

# --- OPTIONAL ---
# Only needed for AI-powered PDF export. CSV export works without this.
# Get a key from https://abacus.ai/
ABACUSAI_API_KEY=
